# 本地环境
VITE_USER_NODE_ENV = development

# 公共基础路径
VITE_PUBLIC_PATH = /asset

# 路由模式
# Optional: hash | history
VITE_ROUTER_MODE = hash

# 打包时是否删除 console
VITE_DROP_CONSOLE = true

# 是否开启 VitePWA
VITE_PWA = false

# 开发环境接口地址
VITE_API_URL = /api

# 流程引擎域名
VITE_APP_WORKFLOW_DOMAIN = http://192.168.1.100/workflow
# VITE_APP_WORKFLOW_DOMAIN = http://localhost:8899

# 开发环境跨域代理
# VITE_PROXY = [["/api/asset","http://192.168.1.207:7191"],["/api/workflow","http://192.168.1.100:7186"],["/api/infrastructure/sys/file/upload/minio","http://192.168.1.100:7181/sys/file/upload/minio"],["/minio","http://106.55.177.90/minio"],["/api/infrastructure","http://192.168.1.100:7181"],["/api","http://192.168.1.100:7080"]]
